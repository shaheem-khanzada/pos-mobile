{
  "expo": {
    "name": "easypos",
    "slug": "starter-kit-expo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "easypos",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#10B981"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "$(PRODUCT_NAME) needs access to your Camera to capture photos and videos.",
        "NSMicrophoneUsageDescription": "$(PRODUCT_NAME) needs access to your Microphone to record audio for video recordings.",
        "NSBluetoothAlwaysUsageDescription": "$(PRODUCT_NAME) uses Bluetooth to discover and print to nearby receipt printers.",
        "NSBluetoothPeripheralUsageDescription": "$(PRODUCT_NAME) uses Bluetooth to discover and print to nearby receipt printers.",
        "NSLocalNetworkUsageDescription": "$(PRODUCT_NAME) uses the local network to discover printers on Wi‑Fi or Ethernet.",
        "UISupportedExternalAccessoryProtocols": [
          "com.epson.escpos"
        ]
      },
      "bundleIdentifier": "com.anonymous.posh"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#10B981"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.posh"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      "expo-font",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#10B981",
          "image": "./assets/images/splash-icon.png",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#047857"
          },
          "imageWidth": 250
        }
      ],
      "expo-audio",
      "expo-asset",
      "expo-camera",
      "expo-image-picker",
      "react-native-ble-plx"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bd5c418c-3d3e-4196-88da-c0ad0e0c1bad"
      }
    },
    "owner": "shaheemkz"
  }
}
